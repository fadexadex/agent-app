# ── AI Provider Keys ─────────────────────────────────────────────────────────
# At least one is required. See server/src/lib/gateway.ts to switch providers.

# Option 5 (default): Google AI Studio (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_genai_api_key_here

# Option 1: Vercel AI Gateway
# AI_GATEWAY_API_KEY=your_gateway_key_here

# Option 2: Anthropic direct
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Option 3: Groq
# GROQ_API_KEY=your_groq_key_here

# Option 6: OpenRouter (free models — recommended: qwen/qwen3-coder:free)
# OPENROUTER_API_KEY=your_openrouter_key_here

# ── Server Configuration ─────────────────────────────────────────────────────
PORT=3001

# CORS_ORIGIN: Comma-separated list of frontend origins allowed to call the API.
# In production set this to your deployed frontend URL, e.g.:
#   CORS_ORIGIN=https://your-app.example.com
# On a local network, use your machine's IP:
#   CORS_ORIGIN=http://192.168.1.100:8080
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# ── Render Mode ─────────────────────────────────────────────────────────────
# Set to "true" to use local remotion rendering instead of AWS Lambda
USE_LOCAL_RENDER=true

# Maximum retries for Gemini-backed AI SDK calls
GEMINI_MAX_RETRIES=5

# Set to "false" for text-only models that don't support image input
# Defaults to true — leave unset for vision-capable models (Gemini, Gemma, Anthropic)
# AGENT_SUPPORTS_VISION=false
