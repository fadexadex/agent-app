# Copy to `.env` in this folder (gitignored). Restart Vite after changes.
#
# Required for `npm run dev` / Vite dev server: proxy target for /api, /previews, /exports, /uploads.
# You choose local or deployed — there is no default.
#
# Local API:
# VITE_API_PROXY_TARGET=http://localhost:3001
#
# Deployed API:
# VITE_API_PROXY_TARGET=https://your-app.example.com

VITE_API_PROXY_TARGET=
